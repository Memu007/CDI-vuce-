# CDI Sistema MARÍA - Environment Variables Example
# Copy this file to .env and fill in your actual values

# ===== SENTRY ERROR TRACKING =====
# Get your DSN from https://sentry.io/settings/projects/
SENTRY_DSN=https://your-sentry-dsn-here@o1234567890.ingest.sentry.io/1234567890

# ===== ENVIRONMENT =====
# Options: development, staging, production
ENVIRONMENT=development

# ===== GEMINI API =====
# Get your API key from https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ===== DATABASE =====
# PostgreSQL connection (if using external DB)
# DATABASE_URL=postgresql://user:password@localhost:5432/maria_db

# ===== LOGGING =====
# Logging configuration
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_JSON=true
LOG_CONSOLE=true
LOG_FILE=true
ENABLE_REQUEST_LOGGING=true

# ===== RATE LIMITING =====
# Requests per minute limits
API_RATE_LIMIT=3000/minute
RATE_LIMIT_BASIC=3000/minute
RATE_LIMIT_PREMIUM=5000/minute

# ===== SECURITY =====
# JWT secret key (generate a random string)
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=43200

# ===== CORS =====
# Comma-separated list of allowed origins
# IMPORTANTE: en prod no puede ser "*" porque la app usa cookies HttpOnly.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ===== FRONTEND URL =====
# Base publica desde la que se sirve la UI. Usada para armar los links
# que se envian por email (reset password, verificacion de cuenta).
# En dev default a http://127.0.0.1:8010. En prod ES OBLIGATORIO definirla.
FRONTEND_URL=http://127.0.0.1:8010

# ===== SMTP (email transaccional) =====
# Si falta cualquiera de estas vars, los emails se loguean a consola en
# lugar de enviarse (modo mock). En prod configurar todas.
# SMTP_SERVER=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=your-sendgrid-api-key
# SMTP_FROM_EMAIL=no-reply@cdi.tu-dominio.com

# ===== EMAIL VERIFICATION =====
# Si true, el registro crea el user con is_verified=False y manda email
# con link. Default false para no bloquear testers en dev/beta.
EMAIL_VERIFICATION_REQUIRED=false

# ===== PORT =====
# Server port (Cloud Run uses PORT env var)
PORT=8080

# ===== CACHE =====
# Redis configuration (if using Redis cache)
# REDIS_URL=redis://localhost:6379
# CACHE_TTL_SECONDS=3600

# ===== AFIP =====
# AFIP Web Services configuration
# Modos soportados: fake | api. Si AFIP_MODE no esta seteado, se infiere
# "api" cuando hay AFIP_CUIT + AFIP_CERT_PATH, y "fake" en caso contrario.
# AFIP_MODE=fake
# AFIP_CERT_PATH=/path/to/cert.crt
# AFIP_KEY_PATH=/path/to/private.key
# AFIP_CUIT=your-cuit-here

# ===== NCM DATA SOURCES (VUCE / Tarifar) =====
# Modos soportados por cada connector:
#   fake   - respuesta simulada (sin red). Default hasta tener credenciales.
#   scrape - datos reales via scraping publico (tarifar.com + arancel.com.ar).
#   api    - API oficial (requiere API key). Hoy: placeholder.
#
# Si VUCE_MODE no esta seteado, se respeta VUCE_FAKE_MODE legacy (true = fake).
VUCE_MODE=scrape
# VUCE_API_KEY=your-vuce-api-key-here       # solo si VUCE_MODE=api
# VUCE_BASE_URL=https://sandbox.vuce.gob.ar/api

TARIFAR_MODE=scrape
# TARIFAR_API_KEY=your-tarifar-api-key-here  # solo si TARIFAR_MODE=api
# TARIFAR_BASE_URL=https://api.tarifar.com

# TTL del cache persistente de NCM en horas. Default: 168 (1 semana).
# Las alicuotas cambian poco (por decreto), asi que 7 dias es conservador.
NCM_CACHE_TTL_HOURS=168

# Rate limit y User-Agent del scraper (solo si VUCE_MODE=scrape).
# NCM_SCRAPER_MIN_INTERVAL_MS=1000
# NCM_SCRAPER_TIMEOUT=8
# NCM_SCRAPER_USER_AGENT=CDI-NCM-Bot/1.0 (+https://cdi.local)

# ===== GOOGLE CLOUD =====
# Google Cloud project configuration
# GCP_PROJECT_ID=cdi-sistema-maria
# GCP_REGION=us-central1
